DEV_POSTGRES_PORT=54329
DEV_REDIS_PORT=63791
DEV_MINIO_PORT=9000
DEV_MINIO_CONSOLE_PORT=9001
WEB_PORT=5173
CHAT_PORT=4310
RESOLVER_PORT=4311
DEV_API_PORT=4312
WATCHLISTS_PORT=4313
MARKET_PORT=4321
FUNDAMENTALS_PORT=4322
SCREENER_PORT=4323
PORTFOLIO_PORT=4333
HOME_PORT=4334
EVIDENCE_PORT=4335
DEV_PROVIDERS_PORT=4336
# Comma-separated tickers for the Home market-pulse strip. On startup, dev
# hydrates these through provider-backed identity discovery when POLYGON_API_KEY
# is set; otherwise they remain unavailable rather than falling back to seeds.
HOME_PULSE_TICKERS=AAPL,MSFT,GOOGL
DEV_POSTGRES_USER=postgres
DEV_POSTGRES_PASSWORD=postgres
DEV_POSTGRES_DB=market_agent
MA_FLAG_PLACEHOLDER_API=true
MA_FLAG_SHOW_DEV_BANNER=false
MA_FLAG_LLM_SETTINGS=true
VITE_MA_FLAG_LLM_SETTINGS=true

# Local LLM channel settings. The dev shell exports LLM_SETTINGS_ENV_FILE to
# .env.dev so the Settings UI can update these fields without restarting the
# shell. API keys are masked in the UI and preserved when saved unchanged.
LLM_CHANNELS=
# LLM_OPENAI_PROTOCOL=openai
# LLM_OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_OPENAI_API_KEY=
# LLM_OPENAI_MODELS=gpt-4.1,o3
# LLM_DEEPSEEK_PROTOCOL=openai-compatible
# LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# LLM_DEEPSEEK_API_KEY=
# LLM_DEEPSEEK_MODELS=deepseek-chat
# LITELLM_MODEL=openai/gpt-4.1
# LITELLM_FALLBACK_MODELS=deepseek/deepseek-chat,openai/o3
# AGENT_LITELLM_MODEL=openai/o3

# Optional provider wiring. Without POLYGON_API_KEY, provider-backed ticker and
# market surfaces return unavailable/not_found instead of fixture data. With a
# key, resolver startup/on-demand discovery persists stock identities and market
# requests cache Polygon quotes/bars in Postgres.
POLYGON_API_KEY=
# RESOLVER_POLYGON_REFERENCE_BASE_URL=https://api.polygon.io
# POLYGON_API_BASE_URL=https://api.polygon.io

# Explicit opt-in for unofficial local-dev provider fallback. When enabled,
# dev-shell starts services/dev-providers and resolver/market can use yfinance
# after provider-backed Polygon lookup/cache paths miss or are unavailable.
ENABLE_UNOFFICIAL_DEV_PROVIDERS=false
# DEV_PROVIDERS_ORIGIN=http://127.0.0.1:4336

# Required by SEC EDGAR for live companyfacts ingestion. Include an app/contact
# string you control, e.g. "market-agent-dev you@example.com".
SEC_EDGAR_USER_AGENT=
# SEC_EDGAR_BASE_URL=https://data.sec.gov

# GDELT public news discovery. This integration is metadata-only by default;
# snippets may be passed transiently to reader tools, but full article bodies
# are not stored unless a later source-specific license review explicitly
# permits it.
GDELT_DISCOVERY_ENABLED=false
GDELT_DOC_API_BASE_URL=https://api.gdeltproject.org/api/v2/doc/doc
GDELT_DISCOVERY_STORE_POLICY=metadata_only
GDELT_DISCOVERY_DEFAULT_MAX_RECORDS=100
GDELT_DISCOVERY_RATE_LIMIT_PER_SECOND=1

# Object storage for raw document blobs (P3.1).
# BLOB_STORE_BACKEND=memory uses MemoryObjectStore (in-process, dev only).
# BLOB_STORE_BACKEND=s3 uses S3ObjectStore against any S3-compatible API.
# The MinIO defaults below match the docker-compose.dev.yml service.
BLOB_STORE_BACKEND=memory
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=evidence-blobs
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
