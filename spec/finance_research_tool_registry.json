{
  "version": "1.0.0",
  "description": "Normative tool registry for the commodities analyst terminal. Tools are deterministic data/action surfaces; Block[] remains the separate response artifact contract.",
  "design_rules": [
    "System selects the commodity tool bundle; model selects tools within the bundle.",
    "Reader-only tools may access raw licensed or internal content; analyst-facing tools receive structured report deltas, events, facts, and summaries.",
    "Tool inputs and outputs must validate against JSON Schema.",
    "All market levels, spreads, balance values, events, and report deltas must carry source refs or deterministic computation refs.",
    "Daily-call publish actions require analyst approval and produce snapshot-bound artifacts.",
    "The product supports decision briefs and analyst drafting, not autonomous trade execution."
  ],
  "bundles": [
    {
      "bundle_id": "commodity_quote_lookup",
      "description": "Fast commodity latest-price, benchmark, and contract lookups"
    },
    {
      "bundle_id": "curve_analysis",
      "description": "Commodity curve, spread, and inventory-linked price analysis"
    },
    {
      "bundle_id": "report_delta_analysis",
      "description": "Licensed report and internal-note delta analysis"
    },
    {
      "bundle_id": "event_impact_analysis",
      "description": "Event-impact graph research over drivers, claims, and market horizons"
    },
    {
      "bundle_id": "balance_snapshot",
      "description": "Supply-demand, inventory, trade-flow, and house-forecast balance views"
    },
    {
      "bundle_id": "daily_call_run",
      "description": "Copper and iron ore daily market-call drafting with analyst signoff"
    },
    {
      "bundle_id": "forecast_assumption_review",
      "description": "House forecast, market curve, and assumption-delta review"
    },
    {
      "bundle_id": "alert_management",
      "description": "Material-change alert setup and approval-mediated notification actions"
    }
  ],
  "tools": [
    {
      "name": "resolve_subjects",
      "audience": "analyst",
      "bundles": [
        "commodity_quote_lookup",
        "curve_analysis",
        "report_delta_analysis",
        "event_impact_analysis",
        "balance_snapshot",
        "daily_call_run",
        "forecast_assumption_review",
        "alert_management"
      ],
      "description": "Resolve free-form commodity, benchmark, contract, curve, region, delivery point, asset, producer, route, market theme, portfolio, or screen text into canonical subject refs.",
      "read_only": true,
      "approval_required": false,
      "cost_class": "low",
      "freshness_expectation": "varies",
      "input_json_schema": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "allow_kinds": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/CommoditySubjectKind"
            }
          }
        },
        "required": [
          "text"
        ],
        "additionalProperties": false,
        "$defs": {
          "CommoditySubjectKind": {
            "type": "string",
            "enum": [
              "commodity",
              "benchmark",
              "contract",
              "curve",
              "region",
              "delivery_point",
              "asset",
              "producer",
              "route",
              "market_theme",
              "portfolio",
              "screen"
            ]
          }
        }
      },
      "output_json_schema": {
        "type": "object",
        "properties": {
          "subjects": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "subject_ref",
                "display_name",
                "confidence"
              ],
              "properties": {
                "subject_ref": {
                  "$ref": "#/$defs/SubjectRef"
                },
                "display_name": {
                  "type": "string"
                },
                "confidence": {
                  "type": "number"
                },
                "ambiguity_axis": {
                  "type": "string",
                  "enum": [
                    "grade",
                    "benchmark",
                    "location",
                    "delivery_month",
                    "route",
                    "none"
                  ]
                }
              },
              "additionalProperties": false
            }
          },
          "unresolved": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "subjects",
          "unresolved"
        ],
        "additionalProperties": false,
        "$defs": {
          "SubjectRef": {
            "type": "object",
            "required": [
              "kind",
              "id"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "commodity",
                  "benchmark",
                  "contract",
                  "curve",
                  "region",
                  "delivery_point",
                  "asset",
                  "producer",
                  "route",
                  "market_theme",
                  "portfolio",
                  "screen"
                ]
              },
              "id": {
                "type": "string",
                "format": "uuid"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "error_codes": [
        "INVALID_ARGUMENT",
        "NOT_FOUND",
        "UPSTREAM_UNAVAILABLE",
        "RATE_LIMITED",
        "POLICY_BLOCKED"
      ]
    },
